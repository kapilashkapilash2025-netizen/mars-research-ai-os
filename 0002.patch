+class TestEvaluation:
+    def test_evaluation_case_requires_expected_documents(self) -> None:
+        with pytest.raises(ValueError, match="expected_document_ids cannot be empty"):
+            EvaluationCase(question="q", expected_document_ids=())
+
+    def test_outcome_hit_at_1_and_reciprocal_rank(self) -> None:
+        case = EvaluationCase(question="q", expected_document_ids=("doc-b",))
+        outcome = EvaluationOutcome(
+            case=case, retrieved_document_ids=("doc-a", "doc-b", "doc-c"), top_score=0.9
+        )
+        assert outcome.hit_at_1 is False
+        assert outcome.hit_at_3 is True
+        assert outcome.reciprocal_rank == pytest.approx(0.5)
+
+    def test_outcome_with_no_matches_scores_zero(self) -> None:
+        case = EvaluationCase(question="q", expected_document_ids=("doc-z",))
+        outcome = EvaluationOutcome(
+            case=case, retrieved_document_ids=("doc-a", "doc-b"), top_score=0.1
+        )
+        assert outcome.hit_at_1 is False
+        assert outcome.hit_at_3 is False
+        assert outcome.reciprocal_rank == 0.0
+
+    def test_run_evaluation_against_real_service(self) -> None:
+        service = KnowledgeService(
+            connectors=(
+                StaticDocumentConnector(
+                    (
+                        _document("doc-moons", "Phobos and Deimos are the two moons of Mars."),
+                        _document("doc-weather", "Dust storms on Mars can last for weeks."),
+                    )
+                ),
+            )
+        )
+        service.start()
+        cases = (
+            EvaluationCase(
+                question="How many moons does Mars have?",
+                expected_document_ids=("doc-moons",),
+            ),
+        )
+
+        report = run_evaluation(service, cases)
+
+        assert report.case_count == 1
+        assert report.hit_rate_at_1 == 1.0
+        assert report.mean_reciprocal_rank == 1.0
+        assert report.failing_cases() == ()
+        service.stop()
+
+    def test_report_rejects_empty_outcomes(self) -> None:
+        with pytest.raises(ValueError, match="outcomes cannot be empty"):
+            EvaluationReport(outcomes=())
+
+    def test_run_evaluation_rejects_empty_cases(self) -> None:
+        service = KnowledgeService(connectors=(StaticDocumentConnector((_document(),)),))
+        service.start()
+        with pytest.raises(ValueError, match="cases cannot be empty"):
+            run_evaluation(service, ())
+
+    def test_bundled_sample_evaluation_meets_baseline(self) -> None:
+        """Regression guard against the bundled labeled questions.
+
+        These are the measured baseline numbers for the default,
+        dependency-free HashingEmbedder (see docs/KNOWLEDGE_ENGINE.md):
+        hit_rate_at_1 ~0.71, hit_rate_at_3 = 1.0, MRR ~0.86. It is not
+        perfect recall@1 — HashingEmbedder is lexical hashing, not a
+        trained model, and two questions rank a longer, topically varied
+        document above the exact match. That gap is the concrete target
+        a real embedding model should close. A drop below these numbers
+        means an embedder/chunking change made retrieval worse.
+        """
+
+        report = run_knowledge_evaluation()
+
+        assert report.hit_rate_at_3 == 1.0, report.to_dict()
+        assert report.mean_reciprocal_rank >= 0.8, report.to_dict()
+        assert report.hit_rate_at_1 >= 0.6, report.to_dict()
+
